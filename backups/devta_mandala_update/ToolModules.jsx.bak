/**
 * TOOL MODULES COMPONENT - FULL VERSION
 * Multiple Entrances Enabled with Zone Badges & Elements
 */
export default function ToolModules({ onBack }) {
  const navigate = useNavigate();
  const theme = useTheme();
  const isMobile = useMediaQuery(theme.breakpoints.down("sm"));

  // Project Context
  const activeProjectId = localStorage.getItem("active_project_id");
  const userEmail = localStorage.getItem("email");
  const [saveStatus, setSaveStatus] = useState("idle"); // idle, saving, saved, error
  const [isExporting, setIsExporting] = useState(false);

  // Auto-Save Effect
  useEffect(() => {
    if (!activeProjectId || !userEmail) return;

    const intervalId = setInterval(async () => {
      setSaveStatus("saving");
      const res = await saveProjectProgress(activeProjectId, userEmail);
      if (res.status === "success") {
        setSaveStatus("saved");
        setTimeout(() => setSaveStatus("idle"), 2000);
      } else {
        setSaveStatus("error");
      }
    }, 30000); // Auto-save every 30 seconds

    return () => clearInterval(intervalId);
  }, [activeProjectId, userEmail]);

  const handleManualSave = async () => {
    setSaveStatus("saving");
    const res = await saveProjectProgress(activeProjectId, userEmail);
    if (res.status === "success") {
      setSaveStatus("saved");
      setTimeout(() => setSaveStatus("idle"), 2000);
    } else {
      setSaveStatus("error");
    }
  };
  const { points, active: isPlotActive, toggleMeasure } = useMeasure();
  const {
    isActive, rotation, zoneCount,
    lineThickness, labelSize, labelDistance,
    setActive, setRotation, setZoneCount,
    setLineThickness, setLabelSize, setLabelDistance,
    reset
  } = useShaktiChakra();
  const devta = useDevta();
  const marma = useMarma();
  const { isActive: isGridActive, toggleGrid } = useGrid();
  const centerPoint = useCenterPoint();

  // --- SMART EXPORT LOGIC ---
  const handleSmartExport = (item, isShaktiVariant = false) => {
    if (!validateStep('export')) return;
    setIsExporting(true);

    const reportType = item.type;
    const withShakti = isShaktiVariant || reportType === 'shakti' || reportType === 'zone';

    // 1. Set Global Export Settings for Layers to consume
    window.vastuExportSettings = {
      reportType,
      withShakti,
      active: true
    };

    // 2. Dispatch event to force all layers to re-render with export settings
    window.dispatchEvent(new CustomEvent('vastu-export-update', {
      detail: window.vastuExportSettings
    }));

    // 3. Capture Current State for restoration
    const wasDevtaOn = devta.isActive;
    const wasMarmaOn = marma.isActive;
    const wasShaktiOn = isActive;
    const wasOverlayOn = drawingService.getOverlay();

    // 4. Temporary State sync (for older layers/hooks not yet using export settings)
    const targetDevta = reportType === 'devta';
    const targetMarma = reportType === 'marma';
    const targetShakti = withShakti;

    if (wasDevtaOn !== targetDevta) devta.setActive(targetDevta);
    if (wasMarmaOn !== targetMarma) {
      if (typeof marma.toggleMarma === 'function') marma.toggleMarma(targetMarma);
    }
    if (wasShaktiOn !== targetShakti) setActive(targetShakti);

    // Force show overlay layers for export
    drawingService.setOverlay(true);

    // 5. Wait for Render, Export, then Restore
    setTimeout(() => {
      const timestamp = Date.now();
      const shaktiSuffix = withShakti ? '-SHAKTI' : '';
      const filename = `VASTU-${reportType.toUpperCase()}${shaktiSuffix}-${timestamp}.png`;

      const exportOptions = {
        reportType: reportType,
        withShakti: withShakti,
        entrances: entrances, // Always pass for remedy checking
        remedies: remedies,
        includeRemedies: reportType === 'basic' && includeRemedies,
        graphData: areaData
      };

      exportAsImage("vastu-canvas", filename, exportOptions).finally(() => {
        // 6. Restore Original State
        window.vastuExportSettings = { active: false };
        window.dispatchEvent(new CustomEvent('vastu-export-update', {
          detail: window.vastuExportSettings
        }));

        if (wasDevtaOn !== targetDevta) devta.setActive(wasDevtaOn);
        if (wasMarmaOn !== targetMarma) {
          if (typeof marma.toggleMarma === 'function') marma.toggleMarma(wasMarmaOn);
        }
        if (wasShaktiOn !== targetShakti) setActive(wasShaktiOn);

        // Restore overlay visibility
        drawingService.setOverlay(wasOverlayOn);
        setIsExporting(false);
      });
    }, 1000); // 1s for guaranteed paint
  };

  const {
    isExclusionMode,
    toggleExclusionMode,
    setExclusionMode,
    currentPolygon,
    exclusionPolygons,
    closePolygon,
    undoPoint: undoExclusionPoint,
    clearAllExclusions,
    deleteLastPolygon
  } = useExclusion();
  const [openAlert, setOpenAlert] = useState(false);

  // --- Snackbar Alert State ---
  const [snackbar, setSnackbar] = useState({ open: false, message: "", severity: "info" });

  const showAlert = (message, severity = "warning") => {
    setSnackbar({ open: true, message, severity });
  };

  const handleSnackbarClose = () => {
    setSnackbar({ ...snackbar, open: false });
  };

  // --- Workflow Validation ---
  const validateStep = (type) => {
    if (points.length < 3) {
      showAlert("पहले 'Step 1: Plot Boundary' draw karein.", "error");
      return false;
    }
    if (!centerPoint) {
      showAlert("पहले Center Point calculate karein (Step 1 mein calculate hota hai).", "error");
      return false;
    }
    return true;
  };

  // --- REMEDY SYSTEM STATE ---
  const [remedies, setRemedies] = useState([]);
  const [selectedRemedy, setSelectedRemedy] = useState(null);
  const [selectedEntranceIndex, setSelectedEntranceIndex] = useState(null);
  const [remedyDialogOpen, setRemedyDialogOpen] = useState(false);

  // --- Export State ---
  const [exportReportType, setExportReportType] = useState('full');
  const [exportWithShakti, setExportWithShakti] = useState(true);
  const [includeRemedies, setIncludeRemedies] = useState(true); // New: Include remedies in export
  const [graphData, setGraphData] = useState([]);
  const [showGraphDialog, setShowGraphDialog] = useState(false);
  const [shaktiWarningOpen, setShaktiWarningOpen] = useState(false);


  const handleMarmaToggle = (checked) => {
    if (checked) {
      if (!validateStep('marma')) return;
    }
    toggleMarma(checked);
  };

  useEffect(() => {
    fetch("/api/entrance_remedies.php?category=all")
      .then(res => res.json())
      .then(data => {
        if (data.status === 'success') setRemedies(data.data);
      })
      .catch(err => console.error("Error fetching remedies:", err));
  }, []);

  const handleShowRemedy = (remedy, entranceIdx) => {
    setSelectedRemedy(remedy);
    setSelectedEntranceIndex(entranceIdx);
    // Load existing custom remedy if available
    const ent = entrances[entranceIdx];
    if (ent) {
      setCustomRemedyInput(ent.customRemedy || '');
      setUseCustomRemedyToggle(ent.useCustomRemedy || false);
    }
    setRemedyDialogOpen(true);
  };



  // Permissions
  const { allowedTools, loading: loadingPermissions } = usePlanPermissions();

  const [upgradeDialogOpen, setUpgradeDialogOpen] = useState(false);

  // Helper to check permission
  const hasAccess = (toolId) => {
    if (loadingPermissions) return true;
    if (!allowedTools || allowedTools.length === 0) return false;
    return allowedTools.includes(toolId);
  };

  const handleLockedClick = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setUpgradeDialogOpen(true);
  };

  // --- ENTRANCE FEATURE STATE ---
  const {
    isEntranceMode,
    setIsEntranceMode,
    saveEntranceDetails,
    currentEntrance,
    activeCategory,
    resetEntrance,
    tooltipScale,
    setTooltipScale,
    isEditing,
    editIndex,
    setEditState,
    updateEntrance,
    entrances,
    removeEntrance,
    showSpecDialog,
    setShowSpecDialog,
    setActiveCategory
  } = useEntrance();
  const { isActive: isMarmaActive, toggleMarma } = useMarma();

  // --- AREA CALCULATION MEMO ---
  const areaData = React.useMemo(() => {
    if (!centerPoint || points.length < 3) return [];
    return calculateZoneAreas(centerPoint, points, rotation, zoneCount);
  }, [centerPoint, points, rotation, zoneCount]);

  const totalArea = React.useMemo(() => {
    return areaData.reduce((acc, curr) => acc + parseFloat(curr.area), 0);
  }, [areaData]);

  const devtaAreaData = React.useMemo(() => {
    if (!centerPoint || points.length < 3 || !devta.isActive) return [];
    return calculateDevtaAreas(centerPoint, points, rotation, devta.mandalaSize);
  }, [centerPoint, points, rotation, devta.isActive, devta.mandalaSize]);

  const [specInput, setSpecInput] = useState("");
  const [componentDetails, setComponentDetails] = useState({
    itemColor: "",
    wallColor: "",
    ceilingColor: "",
    floorColor: ""
  });

  // Local state for inputs to avoid re-render issues
  const [degreeInput, setDegreeInput] = useState(rotation);
  const [zoneInput, setZoneInput] = useState(zoneCount);

  // Future Elements List
  const extraElements = [
    { name: "Entrance", icon: <MeetingRoomIcon sx={{ fontSize: 16 }} />, pointsNeeded: 2 },
    { name: "Kitchen", icon: <KitchenIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Toilet", icon: <WcIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Mandir", icon: <TempleHinduIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Master Bed", icon: <BedIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Kids Bed", icon: <BedIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "W. Machine", icon: <LocalLaundryServiceIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Locker", icon: <LockIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Study Table", icon: <AutoStoriesIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Dining", icon: <RestaurantIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Office Desk", icon: <WorkIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Fam. Photo", icon: <InsertPhotoIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Trophies", icon: <EmojiEventsIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "O.H. Tank", icon: <WaterDropIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "U.G. Tank", icon: <WaterDropIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Septic Tank", icon: <WashIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Dustbin", icon: <DeleteIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Staircase Area", icon: <StairsIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
    { name: "Staircase Landing", icon: <StairsIcon sx={{ fontSize: 16 }} />, pointsNeeded: 4 },
  ];

  // Sync local state when service state changes
  React.useEffect(() => {
    setDegreeInput(rotation);
  }, [rotation]);

  React.useEffect(() => {
    setZoneInput(zoneCount);
  }, [zoneCount]);

  // --- Handlers ---
  const handleCalculateCG = () => {
    if (points.length < 3) {
      setOpenAlert(true);
      return;
    }
    calculateCenter(points);
  };

  const handleResetAll = () => {
    if (window.confirm("Are you sure you want to clear all markings?")) {
      resetMeasure();
      resetCenter();
      reset();
      // Entrance reset logic
      if (typeof useEntrance.getState().resetEntrance === 'function') {
        useEntrance.getState().resetEntrance();
      }
    }
  };

  const handleDegreeChange = (event, newValue) => {
    setRotation(newValue);
  };

  const handleDegreeInputChange = (e) => {
    const val = e.target.value;
    setDegreeInput(val);
    const numVal = parseFloat(val);
    if (!isNaN(numVal)) {
      setRotation(numVal);
    }
  };

  const handleZoneChange = (e) => {
    const val = e.target.value;
    setZoneInput(val);
    setZoneCount(val);
  };

  // --- CUSTOM REMEDY STATE ---
  const [customRemedyInput, setCustomRemedyInput] = useState("");
  const [useCustomRemedyToggle, setUseCustomRemedyToggle] = useState(false);

  const handleSaveEntranceSpec = () => {
    const targetEnt = isEditing ? entrances[editIndex] : currentEntrance;
    if (!targetEnt) return;

    const zone = getEntranceZone(targetEnt, centerPoint, rotation, 32);

    if (isEditing) {
      updateEntrance(editIndex, {
        specification: specInput,
        zone: zone,
        details: activeCategory === 'Entrance' ? {} : componentDetails
      });
      setEditState(null, false);
    } else {
      saveEntranceDetails(specInput, zone, activeCategory === 'Entrance' ? {} : componentDetails);
    }

    setSpecInput("");
    setComponentDetails({ itemColor: "", wallColor: "", ceilingColor: "", floorColor: "" });
    setShowSpecDialog(false);
  };

  const handleEditItem = (index, ent) => {
    setIsEntranceMode(false); // Turn off placement mode
    setActiveCategory(ent.category || "Entrance");
    setEditState(index, true);
    setSpecInput(ent.specification || "");
    setComponentDetails(ent.details || { itemColor: "", wallColor: "", ceilingColor: "", floorColor: "" });
    setShowSpecDialog(true);
  };

  // const shaktiChakra = useShaktiChakra(); // Removed redundant call by directly using the values from the first call
  const shaktiChakra = {
    isActive, rotation, zoneCount,
    lineThickness, labelSize, labelDistance,
    setActive, setRotation, setZoneCount,
    setLineThickness, setLabelSize, setLabelDistance,
    reset
  };

  return (
    <Box sx={{
      background: "transparent",
      borderRadius: 3,
      p: 1,
      display: "flex",
      flexDirection: "column"
    }}>

      {/* 🔹 HEADER SECTION */}
      <Box sx={{
        mb: 2,
        p: 2,
        borderRadius: 3,
        background: "linear-gradient(135deg,#f97316 0%,#fb923c 100%)",
        color: "#fff",
        boxShadow: "0 4px 15px rgba(249, 115, 22, 0.3)",
        position: "relative"
      }}>
        <Typography fontWeight={800} fontSize={18} letterSpacing={0.5}>
          {localStorage.getItem("active_project_name") || "Vastu Module"}
        </Typography>
        <Typography variant="caption" sx={{ opacity: 0.8, fontWeight: 600 }}>
          ID: {activeProjectId}
        </Typography>
        <Typography fontSize={11} sx={{ opacity: 0.85, fontWeight: 500 }}>
          Advanced Plot Intelligence System v2.0
        </Typography>
        <Tooltip title="Reset Map Markings">
          <IconButton
            onClick={handleResetAll}
            sx={{ position: "absolute", top: 10, right: 10, color: "white" }}
          >
            <RestartAltIcon />
          </IconButton>
        </Tooltip>
      </Box>

      {/* 🔹 MODULES ACCORDIONS */}
      <Box sx={{ flexGrow: 1 }}>
        <Box sx={{ px: 2, mb: 1, display: 'flex', alignItems: 'center', gap: 1 }}>
          <Box sx={{ width: 8, height: 8, borderRadius: '50%', bgcolor: '#ef4444' }} />
          <Typography fontSize={11} color="#ef4444" fontWeight={900}>
            FOR RED LINES: GO TO STEP 1 BELOW
          </Typography>
        </Box>

        {/* --- 1. CENTER OF GRAVITY MODULE --- */}
        <Box onClickCapture={!hasAccess(1) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(1) ? 'pointer' : 'default' }}>
          <Accordion
            disableGutters
            sx={accordionStyle}
            disabled={!hasAccess(1)}
            onChange={(e, expanded) => {
              if (expanded) {
                if (!isPlotActive) toggleMeasure();
                setExclusionMode(false);
                setIsEntranceMode(false);
              } else {
                if (isPlotActive) toggleMeasure();
              }
            }}
          >
            <AccordionSummary expandIcon={hasAccess(1) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: hasAccess(1) ? "#f97316" : "#cbd5e1" }}>1</Box>
                <Typography fontWeight={700} color={hasAccess(1) ? "#334155" : "#94a3b8"}>Center</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails>
              <Typography fontSize={12} color="text.secondary" sx={{ mb: 2 }}>
                Define the plot boundary by clicking at least 3 points on the layout to find the geometric center.
              </Typography>

              <Button
                fullWidth
                variant="contained"
                sx={primaryButtonStyle}
                disabled={points.length < 3}
                onClick={handleCalculateCG}
              >
                Find Center
              </Button>

              <Box sx={{ mt: 2, p: 1, border: "1px solid #f1f5f9", borderRadius: 2 }}>
                <FormControlLabel
                  control={
                    <Switch
                      checked={isGridActive}
                      onChange={(e) => {
                        if (e.target.checked && !validateStep('grid')) return;
                        toggleGrid(e.target.checked);
                      }}
                      size="small"
                      color="primary"
                    />
                  }
                  label={<Typography fontSize={12} fontWeight={700}>Show Vastu Grid (Net View)</Typography>}
                />
              </Box>
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* --- 2. SHAKTI CHAKRA MODULE --- */}
        <Box onClickCapture={!hasAccess(2) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(2) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(2)}>
            <AccordionSummary expandIcon={hasAccess(2) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={stepCircleStyle}>2</Box>
                <Typography fontWeight={700} color={hasAccess(2) ? "#334155" : "#94a3b8"}>Shakti Chakra</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails>
              <ShaktiChakraButton shaktiChakra={shaktiChakra} validate={() => validateStep('shakti')} />
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* --- 3. BASIC VASTU ANALYSIS (MULTIPLE ENTRANCE SUPPORT) --- */}
        <Box onClickCapture={!hasAccess(3) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(3) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(3)}>
            <AccordionSummary expandIcon={hasAccess(3) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={stepCircleStyle}>3</Box>
                <Typography fontWeight={700} color={hasAccess(3) ? "#334155" : "#94a3b8"}>Basic Vastu Analysis</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails>              <Typography fontSize={11} color="text.secondary" sx={{ mb: 2, fontStyle: 'italic' }}>
              Click a button below, then mark a point, line, or polygon on the layout.
            </Typography>

              <Grid container spacing={1}>
                {extraElements.map((el, i) => {
                  const isActiveTool = el.name === activeCategory && isEntranceMode;
                  return (
                    <Grid size={{ xs: 4 }} key={i}>
                      <Button
                        fullWidth
                        variant="contained"
                        size="small"
                        onClick={() => {
                          const isSameCategory = activeCategory === el.name;
                          // If same category and already on, turn off.
                          // If different category, just switch.
                          const newVal = isSameCategory ? !isEntranceMode : true;

                          // Mutual Exclusivity
                          if (newVal) {
                            setExclusionMode(false);
                            if (isPlotActive) toggleMeasure();
                          }

                          setIsEntranceMode(newVal, el.name, el.pointsNeeded);
                        }}
                        sx={{
                          fontSize: 10,
                          fontWeight: 700,
                          py: 1.2,
                          px: 0.5,
                          minHeight: 46,
                          textTransform: "none",
                          lineHeight: 1.2,
                          display: 'flex',
                          flexDirection: 'column',
                          alignItems: 'center',
                          justifyContent: 'center',
                          transition: "all 0.2s cubic-bezier(0.4, 0, 0.2, 1)",
                          borderRadius: 2.5,

                          // THEME: Premium White Card
                          bgcolor: isActiveTool ? "#f97316" : "#fff",
                          color: isActiveTool ? "#fff" : "#475569",
                          border: isActiveTool ? "1px solid #f97316" : "1px solid #f1f5f9",
                          opacity: 1, // All are now supported
                          boxShadow: isActiveTool
                            ? "0 4px 12px rgba(249, 115, 22, 0.4)"
                            : "0 2px 4px rgba(0,0,0,0.03)",

                          "&:hover": {
                            bgcolor: isActiveTool ? "#ea580c" : "#fff",
                            transform: "translateY(-2px)",
                            boxShadow: isActiveTool
                              ? "0 6px 15px rgba(249, 115, 22, 0.5)"
                              : "0 5px 12px rgba(0,0,0,0.08)",
                            borderColor: isActiveTool ? "#ea580c" : "#cbd5e1",
                          },
                          "&:active": {
                            transform: "translateY(0px)",
                          }
                        }}
                      >
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 0.2 }}>
                          <Typography fontSize={11} fontWeight={900} sx={{ opacity: 0.7 }}>+</Typography>
                          <Typography fontSize={10.5} fontWeight={800} letterSpacing={-0.2}>
                            {el.name}
                          </Typography>
                        </Box>
                      </Button>
                    </Grid>
                  );
                })}
              </Grid>

              {isEntranceMode && (
                <Box sx={{ ...noteBoxStyle, mt: 2 }}>
                  <InfoOutlinedIcon sx={{ fontSize: 16, mr: 1 }} />
                  <Typography fontSize={11}>
                    {activeCategory} marking active. Click {activeCategory === 'Entrance' ? '2' : '4'} points on the map.
                  </Typography>
                </Box>
              )}

              <Divider sx={{ my: 2 }} />

              <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', mb: 1 }}>
                <Typography fontSize={12} fontWeight={800} color="#334155">
                  Marked Components ({entrances.length})
                </Typography>
                {entrances.length > 0 && (
                  <Button
                    size="small"
                    color="error"
                    onClick={() => { if (window.confirm("Clear all marked components?")) resetEntrance(); }}
                    sx={{ fontSize: 9, fontWeight: 700, p: 0 }}
                  >
                    Clear All
                  </Button>
                )}
              </Box>

              {/* Tooltip Size Controller */}
              <Box sx={{ px: 1, mb: 1.5 }}>
                <Typography fontSize={10} fontWeight={700} color="text.secondary" sx={{ mb: 0.5, display: 'flex', justifyContent: 'space-between' }}>
                  BOX SIZE (ZOOM) <span>{tooltipScale.toFixed(1)}x</span>
                </Typography>
                <Slider
                  size="small"
                  value={tooltipScale}
                  min={0.5}
                  max={2.5}
                  step={0.1}
                  onChange={(e, val) => setTooltipScale(val)}
                  sx={{
                    color: '#f97316',
                    height: 4,
                    '& .MuiSlider-thumb': {
                      width: 12,
                      height: 12,
                      backgroundColor: '#fff',
                      border: '2px solid #f97316',
                    },
                    '& .MuiSlider-track': { border: 'none' },
                    '& .MuiSlider-rail': { opacity: 0.3 }
                  }}
                />
              </Box>

              <List id="vastu-analysis-list" dense sx={{ width: '100%', bgcolor: '#f8fafc', borderRadius: 2 }}>
                {entrances.length === 0 ? (
                  <Typography fontSize={11} color="text.disabled" textAlign="center" py={2}>
                    No components marked yet.
                  </Typography>
                ) : (
                  entrances.map((ent, index) => (
                    <ListItem
                      key={index}
                      secondaryAction={
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                          {(() => {
                            // Precise Zone for Remedy Lookup (Always 32)
                            const preciseZone = getEntranceZone(ent, centerPoint, rotation, 32);

                            const remedyInfo = remedies.find(r => r.zone_code === preciseZone && r.category === (ent.category || 'Entrance'));
                            const isPositive = remedyInfo ? Number(remedyInfo.is_positive) === 1 : false;

                            if (remedyInfo && !isPositive) {
                              return (
                                <Tooltip title={`View Remedy (${preciseZone})`}>
                                  <IconButton
                                    size="small"
                                    sx={{
                                      bgcolor: '#fee2e2',
                                      color: '#ef4444',
                                      border: '1px solid #fca5a5',
                                      width: 24, height: 24,
                                      '&:hover': { bgcolor: '#fecaca' },
                                      zIndex: 10 // Ensure it's above other list items
                                    }}
                                    onMouseDown={(e) => e.stopPropagation()}
                                    onClick={(e) => {
                                      e.preventDefault();
                                      e.stopPropagation();
                                      console.log("Opening remedy for:", remedyInfo); // Debug log
                                      handleShowRemedy(remedyInfo, index);
                                    }}
                                  >
                                    <MedicationIcon sx={{ fontSize: 14 }} />
                                  </IconButton>
                                </Tooltip>
                              );
                            }
                            return null;
                          })()}

                          <Tooltip title="Edit Details">
                            <IconButton edge="end" size="small" onClick={() => handleEditItem(index, ent)}>
                              <EditOutlinedIcon fontSize="small" sx={{ color: "#f97316" }} />
                            </IconButton>
                          </Tooltip>
                          <IconButton edge="end" size="small" onClick={() => removeEntrance(index)}>
                            <DeleteOutlineIcon fontSize="small" color="error" />
                          </IconButton>
                        </Box>
                      }
                      sx={{ borderBottom: "1px solid #e2e8f0" }}
                    >
                      {(() => {
                        const preciseZone = getEntranceZone(ent, centerPoint, rotation, 32);
                        const remedyInfo = remedies.find(r => r.zone_code === preciseZone && r.category === (ent.category || 'Entrance'));
                        const isPositive = remedyInfo ? Number(remedyInfo.is_positive) === 1 : false;

                        // Dynamic Icon
                        const categoryIcon = extraElements.find(e => e.name === ent.category)?.icon || <MeetingRoomIcon sx={{ fontSize: 20 }} />;

                        return (
                          <ListItemText
                            primary={
                              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                                <Box sx={{ color: "#f97316", display: 'flex' }}>
                                  {React.cloneElement(categoryIcon, { sx: { fontSize: 18 } })}
                                </Box>
                                {ent.specification || `${ent.category || 'Entrance'} ${index + 1}`}
                              </Box>
                            }
                            primaryTypographyProps={{ fontSize: 12, fontWeight: 800, component: 'div' }}
                            secondaryTypographyProps={{ component: 'div' }}
                            secondary={
                              <>
                                <Box sx={{ display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 0.5 }}>
                                  <Chip
                                    label={`Zone: ${preciseZone}`}
                                    size="small"
                                    sx={{
                                      height: 18,
                                      fontSize: 10,
                                      bgcolor: Number(isPositive) === 1 ? "#dcfce7" : "#fee2e2",
                                      color: Number(isPositive) === 1 ? "#166534" : "#991b1b",
                                      border: `1px solid ${Number(isPositive) === 1 ? "#86efac" : "#fca5a5"}`,
                                      mt: 0.5,
                                      fontWeight: 800
                                    }}
                                  />
                                  {remedyInfo?.is_connected_area == 1 && (
                                    <Chip
                                      label="Connected"
                                      size="small"
                                      sx={{
                                        height: 18,
                                        fontSize: 10,
                                        bgcolor: "#e0f2fe",
                                        color: "#0369a1",
                                        border: "1px solid #bae6fd",
                                        mt: 0.5,
                                        fontWeight: 800
                                      }}
                                    />
                                  )}
                                </Box>
                                <Box sx={{ display: 'flex', alignItems: 'center', mt: 0.5, gap: 0.5 }}>
                                  {Number(isPositive) === 1 ? (
                                    <CheckCircleIcon sx={{ fontSize: 14, color: "#166534" }} />
                                  ) : (
                                    <CancelIcon sx={{ fontSize: 14, color: "#b91c1c" }} />
                                  )}
                                  <Typography
                                    component="div"
                                    fontSize={11}
                                    fontWeight={700}
                                    sx={{
                                      color: Number(isPositive) === 1 ? "#166534" : "#b91c1c"
                                    }}
                                  >
                                    {Number(isPositive) === 1
                                      ? `✔ Excellent placement for ${ent.category || 'Entrance'}`
                                      : `✖ Negative placement for ${ent.category || 'Entrance'}`}
                                    {ent.details && (ent.details.itemColor || ent.details.wallColor) && (
                                      <Box sx={{ mt: 0.5, fontSize: 10, color: 'text.secondary', display: 'flex', flexWrap: 'wrap', gap: 1.5, opacity: 0.9 }}>
                                        {ent.details.itemColor && <span><b>{ent.category}:</b> {ent.details.itemColor}</span>}
                                        {ent.details.wallColor && <span><b>Wall:</b> {ent.details.wallColor}</span>}
                                        {ent.details.ceilingColor && <span><b>Ceiling:</b> {ent.details.ceilingColor}</span>}
                                        {ent.details.floorColor && <span><b>Floor:</b> {ent.details.floorColor}</span>}
                                      </Box>
                                    )}
                                  </Typography>
                                </Box>
                              </>
                            }
                          />
                        );
                      })()}


                    </ListItem>
                  ))
                )}
              </List>
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* --- 4. MARMA MARKING MODULE --- */}
        <Box onClickCapture={!hasAccess(4) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(4) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(4)}>
            <AccordionSummary expandIcon={hasAccess(4) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: hasAccess(4) ? "#f97316" : "#cbd5e1" }}>4</Box>
                <Typography fontWeight={700} color={hasAccess(4) ? "#334155" : "#94a3b8"}>Marma Marking</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails>
              <Typography fontSize={12} color="text.secondary" sx={{ mb: 2 }}>
                Display Marma (Energy) Lines on the layout.
              </Typography>

              <Box sx={{ mb: 2, p: 1, border: "1px solid #f1f5f9", borderRadius: 2 }}>
                <FormControlLabel
                  control={
                    <Switch
                      checked={isMarmaActive}
                      onChange={(e) => handleMarmaToggle(e.target.checked)}
                      color="error"
                    />
                  }
                  label={<Typography fontSize={13} fontWeight={700}>Show Marma Marking</Typography>}
                />
              </Box>

              <Box sx={{ p: 1.5, bgcolor: "#f8fafc", borderRadius: 2, border: "1px dashed #fee2e2" }}>
                <Typography fontSize={11} color="#64748b" sx={{ fontStyle: 'italic' }}>
                  <b>Note:</b> This 9x9 grid and diagonals (Karna Rekha) identify sensitive Marma points where heavy construction or nails should be avoided.
                </Typography>
              </Box>
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* --- OTHER MODULES (Zone Wise Area, Devtas) --- */}
        {/* --- 5. ZONE WISE AREA --- */}
        <Box onClickCapture={!hasAccess(5) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(5) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(5)}>
            <AccordionSummary expandIcon={hasAccess(5) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: hasAccess(5) ? "#f97316" : "#cbd5e1" }}>5</Box>
                <Typography fontWeight={700} color={hasAccess(5) ? "#334155" : "#94a3b8"}>Zone Wise Area</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails>
              {/* Assuming areaData, totalArea, and isActive are calculated/defined in the parent component scope */}
              <Box>
                <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1, px: 1 }}>
                  <Typography fontSize={10} fontWeight={700} color="#64748b">ZONE</Typography>
                  <Box sx={{ display: 'flex', gap: 3 }}>
                    <Typography fontSize={10} fontWeight={700} color="#64748b">AREA</Typography>
                    <Typography fontSize={10} fontWeight={700} color="#64748b">%</Typography>
                  </Box>
                </Box>

                <Box id="vastu-area-report">
                  <List dense disablePadding>
                    {areaData.length > 0 ? areaData.map((data, idx) => (
                      <ListItem key={idx} sx={{ py: 0.5, px: 1, borderBottom: '1px solid #f1f5f9' }}>
                        <Box sx={{ display: 'flex', alignItems: 'center', flexGrow: 1 }}>
                          <Box sx={{ width: 8, height: 8, borderRadius: '50%', bgcolor: data.color, mr: 1.5 }} />
                          <Typography fontSize={12} fontWeight={600} color="#334155">{data.zone}</Typography>
                        </Box>
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 2, minWidth: 80, justifyContent: 'flex-end' }}>
                          <Typography fontSize={12} fontWeight={500} color="#475569">{data.area}</Typography>
                          <Typography fontSize={12} fontWeight={600} color="#1e293b" sx={{ minWidth: 40, textAlign: 'right' }}>{data.percent}</Typography>
                        </Box>
                      </ListItem>
                    )) : (
                      <Typography fontSize={12} color="text.secondary" textAlign="center" py={2}>
                        {!isActive ? "Activate Shakti Chakra first." : "Mark the boundary to calculate areas."}
                      </Typography>
                    )}
                  </List>

                  {areaData.length > 0 && (
                    <Box sx={{ mt: 1, px: 2, py: 1, bgcolor: '#f8fafc', borderRadius: 2, display: 'flex', justifyContent: 'space-between' }}>
                      <Typography fontSize={12} fontWeight={800} color="#334155">TOTAL</Typography>
                      <Box sx={{ display: 'flex', gap: 2 }}>
                        <Typography fontSize={12} fontWeight={800} color="#1e293b">{totalArea.toFixed(2)}</Typography>
                        <Typography fontSize={12} fontWeight={800} color="#1e293b">100.0%</Typography>
                      </Box>
                    </Box>
                  )}
                </Box>

                <Button
                  fullWidth
                  variant="contained"
                  disabled={areaData.length === 0}
                  onClick={(e) => {
                    e.stopPropagation(); // Prevent accordion from toggling
                    console.log("[ToolModules] View Graph Clicked. Data:", areaData);
                    setGraphData([...areaData]);
                    setShowGraphDialog(true);
                  }}
                  sx={{ ...primaryButtonStyle, mt: 2 }}
                >
                  View Graph (Analysis)
                </Button>
              </Box>
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* --- 6. DEVTA MANDALA (STEP 1) --- */}
        <Box onClickCapture={!hasAccess(6) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(6) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(6)}>
            <AccordionSummary expandIcon={hasAccess(6) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: hasAccess(6) ? "#f97316" : "#cbd5e1" }}>6</Box>
                <Typography fontWeight={700} color={hasAccess(6) ? "#334155" : "#94a3b8"}>Devta Mandala</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails sx={{ pt: 1, pb: 2 }}>
              <Box sx={{
                p: 2,
                bgcolor: devta.isActive ? 'rgba(249, 115, 22, 0.05)' : '#f8fafc',
                borderRadius: 3,
                border: devta.isActive ? '1px solid #f97316' : '1px solid #e2e8f0',
                transition: 'all 0.3s ease'
              }}>
                <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                  <Box>
                    <Typography fontSize={13} fontWeight={800} color={devta.isActive ? "#ea580c" : "#64748b"}>
                      Devta System
                    </Typography>
                    <Typography fontSize={10} color="#94a3b8">
                      {devta.isActive ? "Mandala is currently active" : "Enable to show sacred markings"}
                    </Typography>
                  </Box>
                  <Switch
                    checked={devta.isActive}
                    onChange={() => devta.toggleActive()}
                    color="warning"
                  />
                </Box>
              </Box>

              {devta.isActive && (
                <Typography fontSize={10} color="#94a3b8" sx={{ mt: 1.5, textAlign: 'center', fontStyle: 'italic' }}>
                  Central Marma and 4 Inner Devtas are visible on the map.
                </Typography>
              )}
            </AccordionDetails>
          </Accordion>
        </Box>

        <Box onClickCapture={!hasAccess(7) ? handleLockedClick : undefined} sx={{ cursor: !hasAccess(7) ? 'pointer' : 'default' }}>
          <Accordion disableGutters sx={accordionStyle} disabled={!hasAccess(7)}>
            <AccordionSummary expandIcon={hasAccess(7) ? <ExpandMoreIcon sx={{ color: "#f97316" }} /> : <LockIcon sx={{ color: "#94a3b8", fontSize: 20 }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: hasAccess(7) ? "#f97316" : "#cbd5e1" }}>7</Box>
                <Typography fontWeight={700} color={hasAccess(7) ? "#334155" : "#94a3b8"}>Devta Exclusion</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails sx={{ pt: 1 }}>
              {/* Devta toggle removed - Shakti Chakra only */}

              {devta.isActive ? (
                <Box sx={{ p: 1.5, bgcolor: 'rgba(249, 115, 22, 0.05)', borderRadius: 3, border: '1px dashed #f97316' }}>
                  <Typography fontSize={11} fontWeight={800} color="#ea580c" sx={{ mb: 1, textTransform: 'uppercase' }}>
                    Exclusion Zones (Hide Markings)
                  </Typography>

                  <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1.5 }}>
                    <Box sx={{
                      p: 1.5,
                      bgcolor: isExclusionMode ? '#fff' : 'rgba(255,255,255,0.5)',
                      border: isExclusionMode ? '2px solid #f97316' : '1px solid #fed7aa',
                      borderRadius: 2,
                      transition: 'all 0.2s'
                    }}>
                      <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', mb: 1 }}>
                        <Typography fontSize={12} fontWeight={700} color={isExclusionMode ? "#ea580c" : "#334155"}>
                          Exclusion Drawing Mode
                        </Typography>
                        <Switch
                          size="small"
                          checked={isExclusionMode}
                          onChange={() => {
                            const newVal = !isExclusionMode;
                            toggleExclusionMode();
                            if (newVal) {
                              if (isPlotActive) toggleMeasure();
                              setIsEntranceMode(false);
                            }
                          }}
                          color="warning"
                        />
                      </Box>
                      <Typography fontSize={10} color="#475569">
                        {isExclusionMode
                          ? "Click on image to draw exclusion area (Box/Object)."
                          : "Enable to draw areas where devta lines will be hidden."}
                      </Typography>
                    </Box>

                    {isExclusionMode && currentPolygon && currentPolygon.points.length > 0 && (
                      <Box sx={{ display: 'flex', gap: 1 }}>
                        <Button
                          fullWidth
                          size="small"
                          variant="outlined"
                          color="warning"
                          onClick={undoExclusionPoint}
                          sx={{ fontSize: 10, fontWeight: 700, borderColor: '#f97316', color: '#ea580c' }}
                        >
                          Undo Point
                        </Button>
                        <Button
                          fullWidth
                          size="small"
                          variant="contained"
                          color="warning"
                          disabled={currentPolygon.points.length < 3}
                          onClick={closePolygon}
                          sx={{ fontSize: 10, fontWeight: 700, bgcolor: '#f97316', '&:hover': { bgcolor: '#ea580c' } }}
                        >
                          Add Zone
                        </Button>
                      </Box>
                    )}

                    {exclusionPolygons.length > 0 && (
                      <Box sx={{ display: 'flex', gap: 1, mt: 1 }}>
                        <Button
                          fullWidth
                          size="small"
                          variant="text"
                          color="warning"
                          onClick={deleteLastPolygon}
                          sx={{ fontSize: 10, fontWeight: 700, color: '#ea580c' }}
                        >
                          Remove Last
                        </Button>
                        <Button
                          fullWidth
                          size="small"
                          variant="text"
                          color="warning"
                          onClick={clearAllExclusions}
                          sx={{ fontSize: 10, fontWeight: 700, color: '#ea580c' }}
                        >
                          Clear All
                        </Button>
                      </Box>
                    )}
                  </Box>
                </Box>
              ) : (
                <Typography fontSize={12} color="text.secondary" textAlign="center" py={2} fontStyle="italic">
                  Activate the Devta System in Step 6 or above to use exclusion.
                </Typography>
              )}
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* 🔹 DIALOG FOR ENTRANCE SPECIFICATION */}
        <Dialog
          open={showSpecDialog}
          disableEnforceFocus
          disableScrollLock
          sx={{ zIndex: 99999 }}
          PaperProps={{ sx: { borderRadius: 4, width: 350 } }}
        >
          <DialogTitle sx={{ fontWeight: 800, fontSize: 18 }}>{activeCategory} Details</DialogTitle>
          <DialogContent>
            <Typography fontSize={13} color="text.secondary" sx={{ mb: 2 }}>
              Provide a label or specification for this entrance (e.g., N1, Balcony).
            </Typography>

            {/* DYNAMIC ZONE PREVIEW */}
            {(() => {
              const previewZone = showSpecDialog && currentEntrance ? getEntranceZone(currentEntrance, centerPoint, rotation, zoneCount) : null;
              const previewRemedyData = remedies.find(r => r.zone_code === previewZone);

              if (previewZone) {
                return (
                  <Box sx={{ mb: 2, p: 1.5, bgcolor: "#f1f5f9", borderRadius: 2, border: "1px dashed #cbd5e1" }}>
                    <Typography fontSize={12} fontWeight={800} color="#334155">
                      Detected Zone: <span style={{ color: "#f97316" }}>{previewZone}</span>
                    </Typography>

                    {previewRemedyData && (
                      <>
                        <Typography fontSize={12} fontWeight={600} color={Number(previewRemedyData.is_positive) ? "#166534" : "#991b1b"} sx={{ mt: 0.5 }}>
                          Type: {Number(previewRemedyData.is_positive) ? "Positive" : "Negative"}
                        </Typography>

                        <Typography fontSize={11} color="text.secondary" sx={{ mt: 0.5 }}>
                          <b>Connected Area:</b> {Number(previewRemedyData.is_connected_area) ? "Yes" : "No"}
                        </Typography>

                        <Typography fontSize={11} sx={{ mt: 1, whiteSpace: 'pre-wrap', fontStyle: 'italic', color: '#475569' }}>
                          <b>Remedy:</b> {previewRemedyData.remedy}
                        </Typography>
                      </>
                    )}
                  </Box>
                );
              }
              return null;
            })()}

            <TextField
              autoFocus
              fullWidth
              label={`${activeCategory} Name / Label`}
              placeholder="e.g. Master Kitchen, Guest Toilet"
              variant="outlined"
              size="small"
              value={specInput}
              onChange={(e) => setSpecInput(e.target.value)}
              sx={{ mb: 2.5 }}
              InputLabelProps={{ shrink: true }}
            />

            {activeCategory !== 'Entrance' && (
              <Box sx={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
                {[
                  { label: `${activeCategory} Color`, key: 'itemColor' },
                  { label: 'Wall Color', key: 'wallColor' },
                  { label: 'Ceiling Color', key: 'ceilingColor' },
                  { label: 'Floor Color', key: 'floorColor' }
                ].map((field) => (
                  <TextField
                    key={field.key}
                    select
                    fullWidth
                    label={field.label}
                    value={componentDetails[field.key]}
                    onChange={(e) => setComponentDetails({ ...componentDetails, [field.key]: e.target.value })}
                    SelectProps={{ native: true }}
                    InputLabelProps={{ shrink: true }}
                    variant="outlined"
                    size="small"
                  >
                    <option value="">Choose {field.label.split(' ')[0]} Color</option>
                    <option value="Yellow">Yellow</option>
                    <option value="Red">Red</option>
                    <option value="Pink">Pink</option>
                    <option value="White">White</option>
                    <option value="Green">Green</option>
                    <option value="Blue">Blue</option>
                    <option value="Black">Black</option>
                    <option value="Beige">Beige</option>
                    <option value="Orange">Orange</option>
                    <option value="Violet">Violet</option>
                    <option value="Grey">Grey</option>
                  </TextField>
                ))}
              </Box>
            )}
          </DialogContent>
          <DialogActions sx={{ p: 3 }}>
            <Button onClick={() => setShowSpecDialog(false)} color="inherit" sx={{ fontWeight: 700 }}>Skip</Button>
            <Button
              onClick={handleSaveEntranceSpec}
              variant="contained"
              sx={primaryButtonStyle}
            >
              {isEditing ? "Update Details" : "Save Details"}
            </Button>
          </DialogActions>
        </Dialog>

        {/* 🔹 DIALOG FOR ERROR HANDLING */}
        <Dialog
          open={openAlert}
          TransitionComponent={Zoom}
          onClose={() => setOpenAlert(false)}
          PaperProps={{ sx: { borderRadius: 4, p: 1, minWidth: 320, textAlign: "center" } }}
        >
          <DialogContent>
            <WarningAmberRoundedIcon sx={{ fontSize: 60, color: "#f97316", mb: 2 }} />
            <DialogTitle sx={{ fontWeight: 800 }}>Insufficient Points</DialogTitle>
            <Typography color="#64748b">
              A minimum of <b>3 points</b> is required to find the geometric center.
            </Typography>
          </DialogContent>
          <DialogActions sx={{ justifyContent: "center", p: 3 }}>
            <Button onClick={() => setOpenAlert(false)} variant="contained" sx={dialogButtonStyle}>
              I Understand
            </Button>
          </DialogActions>
        </Dialog>

        {/* 🔹 UPGRADE DIALOG */}
        <Dialog
          open={upgradeDialogOpen}
          TransitionComponent={Zoom}
          onClose={() => setUpgradeDialogOpen(false)}
          PaperProps={{ sx: { borderRadius: 4, p: 2, minWidth: 350, textAlign: "center" } }}
        >
          <DialogContent sx={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 2 }}>
            <Box sx={{
              width: 60, height: 60, borderRadius: '50%',
              bgcolor: 'rgba(249, 115, 22, 0.1)', color: '#f97316',
              display: 'flex', alignItems: 'center', justifyContent: 'center'
            }}>
              <LockIcon sx={{ fontSize: 32 }} />
            </Box>
            <Box>
              <Typography variant="h6" fontWeight={800} color="#334155" gutterBottom>
                Feature Locked
              </Typography>
              <Typography variant="body2" color="text.secondary">
                This advanced tool is not available in your current plan.
                Upgrade your plan to unlock full access to Vastu intelligence.
              </Typography>
            </Box>
          </DialogContent>
          <DialogActions sx={{ justifyContent: "center", pb: 3, px: 3, flexDirection: 'column', gap: 1 }}>
            <Button
              fullWidth
              variant="contained"
              startIcon={<UpgradeIcon />}
              onClick={() => { setUpgradeDialogOpen(false); navigate('/plans'); }}
              sx={{ ...primaryButtonStyle, fontSize: 15, py: 1.5 }}
            >
              Upgrade Plan
            </Button>
            <Button
              fullWidth
              onClick={() => setUpgradeDialogOpen(false)}
              sx={{ color: "#64748b", fontWeight: 600, textTransform: 'none' }}
            >
              Maybe Later
            </Button>
          </DialogActions>
        </Dialog>

        {/* --- EXTRA DIALOGS --- */}
        <Dialog
          open={remedyDialogOpen}
          onClose={() => setRemedyDialogOpen(false)}
          disableScrollLock
          maxWidth="sm"
          fullWidth
          sx={{ zIndex: 99999 }} // Force top layer
        >
          <DialogTitle sx={{ fontWeight: 900, color: "#9a3412", display: 'flex', alignItems: 'center', gap: 1.5 }}>
            <Box sx={{ bgcolor: 'rgba(249, 115, 22, 0.1)', p: 1, borderRadius: 2, display: 'flex' }}>
              {React.cloneElement(extraElements.find(e => e.name === selectedRemedy?.category)?.icon || <MeetingRoomIcon />, { sx: { fontSize: 24, color: '#f97316' } })}
            </Box>
            <Box>
              <Typography variant="h6" sx={{ fontWeight: 900, lineHeight: 1.2 }}>{selectedRemedy?.category || 'Component'} Remedy</Typography>
              <Typography variant="caption" sx={{ color: '#c2410c', opacity: 0.8 }}>Zone: {selectedRemedy?.zone_code}</Typography>
            </Box>
          </DialogTitle>
          <DialogContent dividers>
            <Typography sx={{ fontWeight: 600, color: "#c2410c", mb: 2 }}>
              This is a Negative Zone.
            </Typography>

            {/* ADMIN REMEDY SECTION */}
            <Box sx={{ p: 2, bgcolor: '#fef2f2', borderRadius: 2, border: '1px solid #fecaca', mb: 3 }}>
              <Typography fontSize={11} fontWeight={800} color="#991b1b" sx={{ mb: 1, textTransform: 'uppercase' }}>
                Admin Panel Remedy
              </Typography>
              <Typography sx={{ display: 'block', whiteSpace: 'pre-wrap', color: '#334155', fontSize: 14 }}>
                {selectedRemedy?.remedy || "No specific remedy available."}
              </Typography>
            </Box>

            <Divider sx={{ my: 2 }} />

            {/* CUSTOM REMEDY SECTION */}
            <Box sx={{ bgcolor: '#f8fafc', p: 2, borderRadius: 2, border: '1px solid #e2e8f0' }}>
              <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', mb: 1.5 }}>
                <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                  <AutoFixHighIcon sx={{ fontSize: 18, color: '#f97316' }} />
                  <Typography fontSize={13} fontWeight={800} color="#334155">Custom Remedy</Typography>
                </Box>
                <FormControlLabel
                  control={
                    <Switch
                      size="small"
                      checked={useCustomRemedyToggle}
                      onChange={(e) => setUseCustomRemedyToggle(e.target.checked)}
                      color="warning"
                    />
                  }
                  label={<Typography fontSize={11} fontWeight={700} color={useCustomRemedyToggle ? '#f97316' : '#94a3b8'}>{useCustomRemedyToggle ? 'Using Custom' : 'Using Admin'}</Typography>}
                  labelPlacement="start"
                  sx={{ m: 0 }}
                />
              </Box>
              <Typography fontSize={11} color="#64748b" sx={{ mb: 1.5 }}>
                {useCustomRemedyToggle
                  ? 'Your custom remedy will be printed when you download the report.'
                  : 'Admin panel remedy will be used. Toggle ON to write your own.'}
              </Typography>
              <TextField
                fullWidth
                multiline
                rows={3}
                disabled={!useCustomRemedyToggle}
                label="Write Your Remedy"
                placeholder="E.g., Place a copper pyramid in the NE corner..."
                variant="outlined"
                size="small"
                value={customRemedyInput}
                onChange={(e) => setCustomRemedyInput(e.target.value)}
                InputLabelProps={{ shrink: true }}
                sx={{
                  '& .MuiOutlinedInput-root': {
                    bgcolor: useCustomRemedyToggle ? '#fff' : '#f1f5f9'
                  }
                }}
              />
            </Box>
          </DialogContent>
          <DialogActions sx={{ p: 2, bgcolor: '#f8fafc', gap: 1 }}>
            <Button onClick={() => setRemedyDialogOpen(false)} sx={{ fontWeight: 700, color: '#64748b' }}>Cancel</Button>
            <Button
              variant="contained"
              onClick={() => {
                if (selectedEntranceIndex !== null) {
                  updateEntrance(selectedEntranceIndex, {
                    customRemedy: customRemedyInput,
                    useCustomRemedy: useCustomRemedyToggle
                  });
                }
                setRemedyDialogOpen(false);
              }}
              sx={{
                fontWeight: 700,
                bgcolor: '#f97316',
                '&:hover': { bgcolor: '#ea580c' },
                textTransform: 'none'
              }}
            >
              Save Remedy Choice
            </Button>
          </DialogActions>
        </Dialog>

        {/* 🔹 GRAPH DIALOG */}
        <Dialog
          open={showGraphDialog}
          onClose={() => setShowGraphDialog(false)}
          fullScreen={isMobile}
          maxWidth="lg"
          fullWidth
          disableEnforceFocus
          disableScrollLock
          sx={{ zIndex: 100001 }}
          PaperProps={{
            sx: {
              borderRadius: isMobile ? 0 : 4,
              p: isMobile ? 1 : 2,
              minHeight: isMobile ? '100vh' : '85vh'
            }
          }}
        >
          <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mb: 2 }}>
            <Typography variant="h6" fontWeight={800} color="#334155">Zone Area Analysis Graph</Typography>
            <IconButton onClick={() => setShowGraphDialog(false)}>
              <CancelIcon sx={{ color: '#94a3b8' }} />
            </IconButton>
          </Box>

          <Box sx={{
            flexGrow: 1,
            width: '100%',
            height: '500px',
            mt: 2,
            overflowX: 'auto',
            overflowY: 'hidden',
            pb: 1,
            '&::-webkit-scrollbar': { height: '8px' },
            '&::-webkit-scrollbar-thumb': { background: '#fed7aa', borderRadius: '10px' },
            '&::-webkit-scrollbar-track': { background: '#fef7ed' }
          }}>
            <Box sx={{
              minWidth: isMobile ? '800px' : '100%',
              height: '100%',
              p: isMobile ? 1 : 0
            }}>
              <ResponsiveContainer width="100%" height="100%">
                {(() => {
                  if (graphData.length === 0) return <Box sx={{ display: 'flex', height: '100%', alignItems: 'center', justifyContent: 'center' }}><Typography color="text.secondary">Waiting for data calculation...</Typography></Box>;

                  // Calculate Stats
                  const values = graphData.map(d => parseFloat(d.area)).filter(v => !isNaN(v));
                  if (values.length === 0) return <Box sx={{ display: 'flex', height: '100%', alignItems: 'center', justifyContent: 'center' }}><Typography color="error">Invalid area data format.</Typography></Box>;

                  const actualMin = Math.min(...values);
                  const actualMax = Math.max(...values);
                  const avg = (values.reduce((a, b) => a + b, 0) / values.length);

                  const maxAvg = (actualMax + avg) / 2;
                  const minAvg = (actualMin + avg) / 2;

                  return (
                    <BarChart
                      data={graphData}
                      margin={{ top: 20, right: isMobile ? 40 : 100, left: 20, bottom: 60 }}
                    >
                      <CartesianGrid strokeDasharray="3 3" vertical={false} />
                      <XAxis
                        dataKey="zone"
                        interval={0}
                        angle={-45}
                        textAnchor="end"
                        height={80}
                        tick={{ fontSize: 11, fontWeight: 700, fill: '#64748b' }}
                      />
                      <YAxis
                        tick={{ fontSize: 11, fill: '#64748b' }}
                        label={{ value: 'Area', angle: -90, position: 'insideLeft', style: { fontSize: 12, fill: '#64748b' } }}
                      />
                      <RechartsTooltip
                        cursor={{ fill: '#f1f5f9' }}
                        contentStyle={{ borderRadius: 8, border: 'none', boxShadow: '0 4px 12px rgba(0,0,0,0.1)' }}
                      />

                      {/* Reference Lines */}
                      <ReferenceLine y={minAvg} stroke="#3b82f6" strokeDasharray="5 5" label={{ position: 'right', value: `Min Avg: ${minAvg.toFixed(0)}`, fill: '#3b82f6', fontSize: 11, fontWeight: 'bold' }} />
                      <ReferenceLine y={avg} stroke="#22c55e" strokeDasharray="5 5" label={{ position: 'right', value: `Avg: ${avg.toFixed(0)}`, fill: '#22c55e', fontSize: 11, fontWeight: 'bold' }} />
                      <ReferenceLine y={maxAvg} stroke="#ef4444" strokeDasharray="5 5" label={{ position: 'right', value: `Max Avg: ${maxAvg.toFixed(0)}`, fill: '#ef4444', fontSize: 11, fontWeight: 'bold' }} />

                      <Bar dataKey="area" radius={[6, 6, 0, 0]}>
                        {graphData.map((entry, index) => (
                          <Cell key={`cell-${index}`} fill={entry.color} />
                        ))}
                      </Bar>
                    </BarChart>
                  );
                })()}
              </ResponsiveContainer>
            </Box>
          </Box>
        </Dialog>

        {/* 🔹 SHAKTI CHAKRA WARNING DIALOG */}
        <Dialog
          open={shaktiWarningOpen}
          onClose={() => setShaktiWarningOpen(false)}
          TransitionComponent={Zoom}
          PaperProps={{ sx: { borderRadius: 4, p: 1, minWidth: 320, textAlign: "center" } }}
        >
          <DialogContent>
            <WarningAmberRoundedIcon sx={{ fontSize: 60, color: "#f97316", mb: 2 }} />
            <DialogTitle sx={{ fontWeight: 800 }}>Shakti Chakra Required</DialogTitle>
            <Typography color="#64748b">
              Marma marking mark karne ke liye <b>shakti chakra</b> add karna zaroori hai.
            </Typography>
          </DialogContent>
          <DialogActions sx={{ justifyContent: "center", p: 3 }}>
            <Button onClick={() => setShaktiWarningOpen(false)} variant="contained" sx={dialogButtonStyle}>
              I Understand
            </Button>
          </DialogActions>
        </Dialog>

        {/* 🔹 SAVE PROJECT SECTION */}
        {
          activeProjectId && (
            <Box sx={{ mt: 3, p: 2, borderTop: '2px solid #f1f5f9', bgcolor: 'rgba(255, 237, 213, 0.3)', borderRadius: '16px 16px 0 0' }}>
              <Typography fontSize={12} fontWeight={800} color="#ea580c" sx={{ mb: 1.5, textTransform: 'uppercase', display: 'flex', alignItems: 'center', gap: 1 }}>
                <CloudDoneIcon sx={{ fontSize: 16 }} /> Project Saving
              </Typography>
              <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Typography fontSize={11} color="text.secondary">
                  {saveStatus === "saved" ? "Values saved to secure database." : "Auto-saving every 30 seconds."}
                </Typography>
                <Button
                  size="small"
                  variant="outlined"
                  startIcon={saveStatus === "saved" ? <CheckCircleIcon /> : <SaveIcon />}
                  onClick={handleManualSave}
                  disabled={saveStatus === "saving"}
                  sx={{
                    textTransform: "none",
                    borderColor: "#fb923c",
                    color: "#ea580c",
                    bgcolor: "white",
                    "&:hover": { bgcolor: "#fff7ed", borderColor: "#f97316" }
                  }}
                >
                  {saveStatus === "saving" ? "Saving..." : saveStatus === "saved" ? "Saved" : "Save Now"}
                </Button>
              </Box>
            </Box>
          )
        }


        {/* --- 6. EXPORT & DOWNLOADS --- */}
        <Box sx={{ mt: 2 }}>
          <Accordion disableGutters sx={{ ...accordionStyle, border: '1px solid #f97316', bgcolor: 'rgba(249, 115, 22, 0.02)' }}>
            <AccordionSummary expandIcon={<ExpandMoreIcon sx={{ color: "#f97316" }} />}>
              <Box sx={summaryHeaderStyle}>
                <Box sx={{ ...stepCircleStyle, bgcolor: "#f97316" }}>
                  <DownloadIcon sx={{ fontSize: 16 }} />
                </Box>
                <Typography fontWeight={800} color="#334155">Export & Downloads</Typography>
              </Box>
            </AccordionSummary>
            <AccordionDetails sx={{ p: 0 }}>
              <Box sx={{ p: 2, bgcolor: '#fff' }}>
                <Typography fontSize={11} color="text.secondary" sx={{ mb: 2, px: 0.5 }}>
                  Choose a report type and your preferred overlay option.
                </Typography>

                <List disablePadding>
                  {[
                    { name: "Basic Vastu Marking", type: "basic", color: "#3b82f6", desc: "Main layout with entrances and components." },
                    { name: "Shakti Chakra", type: "shakti", color: "#8b5cf6", desc: "Clean Shakti Chakra map with 16/32 zones." },
                    { name: "Marma Energy Map", type: "marma", color: "#ef4444", desc: "Detailed Marma points and energy lines." },
                    { name: "Zone Area Analysis", type: "zone", color: "#10b981", desc: "Zone-wise area distribution and chart." },
                    { name: "Devta Mandala", type: "devta", color: "#f59e0b", desc: "The complete 45 Devta Mandala map." },
                  ].map((item, idx) => (
                    <Box key={item.type} sx={{
                      mb: idx === 4 ? 0 : 2.5,
                      p: 1.5,
                      borderRadius: 3,
                      border: '1px solid #f1f5f9',
                      transition: 'all 0.2s',
                      '&:hover': { boxShadow: '0 4px 12px rgba(0,0,0,0.04)', borderColor: '#e2e8f0' }
                    }}>
                      <Box sx={{ display: 'flex', alignItems: 'flex-start', mb: 1.5 }}>
                        <Box sx={{
                          width: 32, height: 32, borderRadius: 2, bgcolor: `${item.color}10`,
                          display: 'flex', alignItems: 'center', justifyContent: 'center', mr: 1.5, flexShrink: 0
                        }}>
                          <DownloadIcon sx={{ fontSize: 18, color: item.color }} />
                        </Box>
                        <Box>
                          <Typography fontSize={13} fontWeight={800} color="#1e293b">{item.name}</Typography>
                          <Typography fontSize={10} color="#64748b" sx={{ mt: 0.2 }}>{item.desc}</Typography>
                        </Box>
                      </Box>

                      <Box sx={{ display: 'flex', gap: 1 }}>
                        {item.type === 'shakti' ? (
                          <Button
                            fullWidth
                            variant="contained"
                            onClick={() => handleSmartExport(item)}
                            sx={{
                              textTransform: 'none', fontWeight: 800, fontSize: 10, borderRadius: 2, py: 1,
                              bgcolor: item.color, '&:hover': { bgcolor: item.color, opacity: 0.9 }
                            }}
                          >
                            Download Shakti Chakra
                          </Button>
                        ) : (
                          <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1.5, width: '100%' }}>
                            {item.type === 'basic' && (
                              <FormControlLabel
                                control={
                                  <Checkbox
                                    checked={includeRemedies}
                                    onChange={(e) => setIncludeRemedies(e.target.checked)}
                                    size="small"
                                    sx={{ p: 0.5, color: '#f97316', '&.Mui-checked': { color: '#f97316' } }}
                                  />
                                }
                                label={<Typography fontSize={11} fontWeight={600} color="#64748b">Include Remedies Section</Typography>}
                                sx={{ m: 0, mb: 0.5 }}
                              />
                            )}
                            {item.type === 'zone' ? (
                              <Button
                                fullWidth
                                variant="contained"
                                startIcon={<AutoFixHighIcon sx={{ fontSize: 14 }} />}
                                onClick={() => handleSmartExport(item, true)}
                                sx={{
                                  textTransform: 'none', fontWeight: 800, fontSize: 10, borderRadius: 2, py: 1,
                                  bgcolor: item.color, '&:hover': { bgcolor: item.color, opacity: 0.9 }
                                }}
                              >
                                Download Analysis Report
                              </Button>
                            ) : (
                              <Box sx={{ display: 'flex', gap: 1 }}>
                                <Button
                                  fullWidth
                                  variant="outlined"
                                  onClick={() => handleSmartExport(item, false)}
                                  sx={{
                                    textTransform: 'none', fontWeight: 700, fontSize: 10, borderRadius: 2, py: 1,
                                    borderColor: '#e2e8f0', color: '#475569', '&:hover': { borderColor: item.color, color: item.color, bgcolor: `${item.color}05` }
                                  }}
                                >
                                  Standard
                                </Button>
                                <Button
                                  fullWidth
                                  variant="contained"
                                  startIcon={<AutoFixHighIcon sx={{ fontSize: 14 }} />}
                                  onClick={() => handleSmartExport(item, true)}
                                  sx={{
                                    textTransform: 'none', fontWeight: 800, fontSize: 10, borderRadius: 2, py: 1,
                                    bgcolor: item.color, '&:hover': { bgcolor: item.color, opacity: 0.9 }
                                  }}
                                >
                                  With Shakti
                                </Button>
                              </Box>
                            )}
                          </Box>
                        )}
                      </Box>
                    </Box>
                  ))}
                </List>
              </Box>
            </AccordionDetails>
          </Accordion>
        </Box>

        {/* 🔹 FOOTER NAVIGATION */}
        <Box sx={{ mt: 2, mb: 1, textAlign: "center" }}>
          <Typography onClick={onBack} sx={backButtonStyle}>
            ← Replace Image
          </Typography>
        </Box>
        {/* 🔹 SNACKBAR ALERTS */}
        <Snackbar
          open={snackbar.open}
          autoHideDuration={4000}
          onClose={handleSnackbarClose}
          anchorOrigin={{ vertical: 'bottom', horizontal: 'center' }}
        >
          <Alert onClose={handleSnackbarClose} severity={snackbar.severity} variant="filled" sx={{ width: '100%', fontWeight: 700 }}>
            {snackbar.message}
          </Alert>
        </Snackbar>

        {/* 🔹 EXPORT PRELOADER (BLUR & LOADER) */}
        <Backdrop
          sx={{
            color: '#fff',
            zIndex: (theme) => 99999,
            flexDirection: 'column',
            gap: 3,
            backdropFilter: 'blur(10px)',
            background: 'rgba(15, 23, 42, 0.75)',
            textAlign: 'center',
            px: 3
          }}
          open={isExporting}
        >
          <CircularProgress color="inherit" size={70} thickness={5} />
          <Box sx={{ maxWidth: 500 }}>
            <Typography variant="h4" sx={{ fontWeight: 900, mb: 2, letterSpacing: '1px', color: '#f97316' }}>
              GENERATING PREMIUM REPORT
            </Typography>
            <Typography sx={{ opacity: 0.95, fontSize: '1.2rem', fontWeight: 600, color: '#fff' }}>
              Please wait while we prepare your high-quality Vastu documentation.
            </Typography>
            <Typography sx={{ opacity: 0.8, mt: 1, fontSize: '1rem', fontStyle: 'italic' }}>
              Your download will commence automatically in a few moments.
            </Typography>
          </Box>
        </Backdrop>
      </Box >
    </Box >
  );
}
